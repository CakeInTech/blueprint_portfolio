# Copy the variables you need into your local `.env` (same directory as compose.yaml).
# Defaults below match compose.yaml — change both places if you customize.

# --- Auth.js (GitHub / Google CMS login) ---
# GitHub OAuth App callback URL: http://localhost:3000/api/auth/callback/github
# (production: https://YOUR_DOMAIN/api/auth/callback/github)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# Comma-separated GitHub/Google account emails allowed to use /cms (must match the email OAuth returns).
ADMIN_EMAILS=you@example.com
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# --- App + Drizzle (required for pnpm dev / db:migrate) ---
# Host is localhost when Next.js runs on your machine and Postgres runs in Docker.
# Use only the URL after the first "=" — do not paste `DATABASE_URL=...` into the value.
# User/password/database must match POSTGRES_* below (defaults = postgres/postgres/portfolio).
# Host port must match POSTGRES_PUBLISH_PORT (default 15432 — change both if the port is taken).
DATABASE_URL=postgresql://postgres:postgres@localhost:15432/portfolio

# --- Docker Compose (substituted into compose.yaml when you run `docker compose up`) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=portfolio
POSTGRES_PUBLISH_PORT=15432

# If `docker compose up` fails with "port is already allocated", pick a free port:
# POSTGRES_PUBLISH_PORT=15433
# DATABASE_URL=postgresql://postgres:postgres@localhost:15433/portfolio

# --- MinIO (hero image uploads from CMS) ---
# After `docker compose up -d`, copy these into `.env` for Next.js (same host ports as compose).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=portfolio-media
MINIO_PUBLISH_PORT=19000
MINIO_CONSOLE_PUBLISH_PORT=19001
# Server-side S3 API (Next.js on host → MinIO published port)
S3_ENDPOINT=http://127.0.0.1:19000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=portfolio-media
S3_REGION=us-east-1
# Public URL the browser uses to load the image (path-style: host + bucket; no trailing slash)
S3_PUBLIC_BASE_URL=http://127.0.0.1:19000/portfolio-media
